---
import Header from '../components/Header.astro';
import { getLangFromUrl, useTranslations, getPath } from '../i18n/utils';
import '@fontsource/playfair-display';
import '@fontsource/inter';

import { execSync } from 'node:child_process';

interface Props {
  title: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title, description = "Edition Atlantis - Premium Book Publisher" } = Astro.props;

const gitHash = (() => {
  try {
    return execSync('git rev-parse --short HEAD').toString().trim();
  } catch (e) {
    return 'no-git-info';
  }
})();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/jpeg" href={getPath("/images/favicon.jpg")} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Edition Atlantis</title>
  </head>
  <body class="bg-background text-gray-900 font-sans antialiased min-h-screen flex flex-col overflow-x-hidden">
    <Header />
    
    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-gray-50 border-t border-gray-100 py-12 mt-20">
      <div class="container mx-auto px-4 text-center text-gray-500 text-sm space-y-3 flex flex-col items-center">
        <p>&copy; {new Date().getFullYear()} Edition Atlantis. {t('footer.rights')}</p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
          <a href={getPath(`/${lang}/about#impressum`)} class="hover:text-primary transition-colors underline decoration-gray-300 underline-offset-4">{t('footer.imprint')}</a>
          <span class="text-gray-300 hidden sm:inline">|</span>
          <a href={getPath(`/${lang}/about#payment`)} class="hover:text-primary transition-colors underline decoration-gray-300 underline-offset-4">{t('about.payment_info')}</a>
          <span class="text-gray-300 hidden sm:inline">|</span>
          <a href={getPath(`/${lang}/about#privacy`)} class="hover:text-primary transition-colors underline decoration-gray-300 underline-offset-4">{t('footer.privacy')}</a>
        </div>
        <p class="text-xs text-gray-400 max-w-lg mx-auto leading-relaxed">{t('footer.privacy_hint')}</p>
        <span class="text-[8px] opacity-0 hover:opacity-20 transition-opacity cursor-default select-all" aria-hidden="true" title="Git Hash">{gitHash}</span>
      </div>
    </footer>
  </body>
</html>
