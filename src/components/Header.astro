---
import Search from './Search.astro';
import { getLangFromUrl, useTranslations, getPath } from '../i18n/utils';
import LanguagePicker from './LanguagePicker.astro';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isActive = (path: string) => {
  // Get pathname and remove base URL if present
  let pathname = Astro.url.pathname;
  const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
  if (baseUrl && pathname.startsWith(baseUrl)) {
    pathname = pathname.substring(baseUrl.length);
  }
  
  // Normalize paths by removing trailing slashes
  const normalizedPathname = pathname.replace(/\/$/, '') || '/';
  const normalizedPath = path.replace(/\/$/, '') || '/';
  
  // Special case for home page
  if (normalizedPath === `/${lang}` || normalizedPath === '/') {
    return normalizedPathname === `/${lang}` || normalizedPathname === '/';
  }
  
  return normalizedPathname.startsWith(normalizedPath);
};
---

<header class="sticky top-0 z-40 w-full bg-white/90 backdrop-blur-md border-b border-gray-100 transition-all duration-300">
  <div class="container mx-auto px-4">
    <div class="h-20 flex items-center justify-between">
      <!-- Logo -->
    <a href={getPath(`/${lang}/`)} class="flex items-center group">
      <img src={getPath("/images/logo.jpg")} alt="Edition Atlantis" class="h-12 w-auto object-contain" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center space-x-8">
      <a href={getPath(`/${lang}/`)} class:list={[
        "text-base font-medium transition-colors tracking-wide border-b-2 py-1",
        isActive(`/${lang}/`) ? "text-accent border-accent" : "text-gray-700 hover:text-accent border-transparent"
      ]}>
        {t('nav.home')}
      </a>
      <a href={getPath(`/${lang}/publications`)} class:list={[
        "text-base font-medium transition-colors tracking-wide border-b-2 py-1",
        isActive(`/${lang}/publications`) ? "text-accent border-accent" : "text-gray-700 hover:text-accent border-transparent"
      ]}>
        {t('nav.publications')}
      </a>
      <a href={getPath(`/${lang}/authors`)} class:list={[
        "text-base font-medium transition-colors tracking-wide border-b-2 py-1",
        isActive(`/${lang}/authors`) ? "text-accent border-accent" : "text-gray-700 hover:text-accent border-transparent"
      ]}>
        {t('nav.authors')}
      </a>
      <a href={getPath(`/${lang}/about`)} class:list={[
        "text-base font-medium transition-colors tracking-wide border-b-2 py-1",
        isActive(`/${lang}/about`) ? "text-accent border-accent" : "text-gray-700 hover:text-accent border-transparent"
      ]}>
        {t('nav.about')}
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center space-x-4">
      <div class="hidden md:block w-72 lg:w-96">
        <Search placeholder={t('search.placeholder')} />
      </div>

      <LanguagePicker />
      
      <!-- Mobile Menu Button (Hamburger) -->
      <button id="mobile-menu-btn" class="md:hidden text-primary focus:outline-none p-2" aria-label="Toggle menu">
        <Icon name="lucide:menu" class="h-6 w-6" />
      </button>
    </div>
    </div>
    <!-- Mobile Search (Always visible) -->
    <div class="md:hidden pb-4">
      <Search placeholder={t('search.placeholder')} />
    </div>
  </div>
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 absolute w-full bg-white shadow-lg">
    <div class="container mx-auto px-4 py-4 space-y-4">
        <nav class="flex flex-col space-y-3">
          <a href={getPath(`/${lang}/`)} class:list={[
            "text-base font-medium transition-colors",
            isActive(`/${lang}/`) ? "text-accent" : "text-gray-700 hover:text-accent"
          ]}>
            {t('nav.home')}
          </a>
          <a href={getPath(`/${lang}/publications`)} class:list={[
            "text-base font-medium transition-colors",
            isActive(`/${lang}/publications`) ? "text-accent" : "text-gray-700 hover:text-accent"
          ]}>
            {t('nav.publications')}
          </a>
          <a href={getPath(`/${lang}/authors`)} class:list={[
            "text-base font-medium transition-colors",
            isActive(`/${lang}/authors`) ? "text-accent" : "text-gray-700 hover:text-accent"
          ]}>
            {t('nav.authors')}
          </a>
          <a href={getPath(`/${lang}/about`)} class:list={[
            "text-base font-medium transition-colors",
            isActive(`/${lang}/about`) ? "text-accent" : "text-gray-700 hover:text-accent"
          ]}>
            {t('nav.about')}
          </a>
        </nav>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
