---
import { getPath, useTranslations } from '../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  publication: CollectionEntry<'publications'>;
  lang: string;
  authorName: string;
  coAuthorNames?: string;
  showFilters?: boolean;
}

const { publication, lang, authorName, coAuthorNames, showFilters = false } = Astro.props;
const t = useTranslations(lang as any);

const authorId = publication.data.author.id;
const coAuthorIds = publication.data.coAuthors ? publication.data.coAuthors.map(a => a.id).join(' ') : '';
const allAuthorIds = `${authorId} ${coAuthorIds}`;
const allAuthorNames = `${authorName}${coAuthorNames ? ' ' + coAuthorNames : ''}`;

// For translations of date
const publicationYear = publication.data.publicationDate ? publication.data.publicationDate.getFullYear() : 'unknown';

const isFuture = publication.data.publicationDate ? publication.data.publicationDate > new Date() : false;
---

<a 
    href={getPath(`/${lang}/publications/${publication.slug}`)} 
    class:list={[
        "publication-item group block bg-white border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1",
        showFilters ? "filtered-item" : ""
    ]}
    data-lang={showFilters ? publication.data.language : undefined}
    data-author={showFilters ? allAuthorIds : undefined}
    data-author-names={showFilters ? allAuthorNames : undefined}
    data-year={showFilters ? publicationYear : undefined}
    data-category={showFilters ? (publication.data.category || '') : undefined}
    data-title={showFilters ? publication.data.title.toLowerCase() : undefined}
    data-isbn={showFilters ? (publication.data.isbn || '') : undefined}
>
  <div class="aspect-[2/3] overflow-hidden bg-gray-100 relative">
    <img 
      src={getPath(publication.data.cover)}
      alt={publication.data.title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
      decoding="async"
      onError={`this.onerror=null;this.src='${getPath("/images/placeholder-publication.png")}';`}
    />
    <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors duration-300"></div>
    
    {isFuture && (
        <div 
          class="absolute top-2 left-2 bg-accent text-white text-[10px] uppercase font-bold px-2 py-1 rounded-sm shadow-md z-10 coming-soon-badge opacity-0 transition-opacity duration-300" 
          data-date={publication.data.publicationDate?.toISOString()}
        >
            {t('publication.coming_soon')}
        </div>
    )}

    {publication.data.price && (
        <div class="absolute bottom-2 right-2 bg-black/70 text-white text-xs px-2 py-1 rounded">
            {Number(publication.data.price).toFixed(2)} €
        </div>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-serif text-lg font-bold text-gray-900 group-hover:text-primary line-clamp-2 leading-tight mb-1" title={publication.data.title}>
      {publication.data.title}
    </h3>
    <p class="text-sm text-accent font-medium mb-1">
        {authorName}{coAuthorNames && (
            <span>, {coAuthorNames}</span>
        )}
    </p>
    <div class="flex justify-between items-center mt-2">
         <p class="text-xs text-gray-400">
          {publication.data.publicationDate ? publication.data.publicationDate.getFullYear() : 'Unknown'}
        </p>
        <span class="text-xs font-bold uppercase text-gray-300 bg-gray-50 px-1 rounded">{publication.data.language}</span>
    </div>
  </div>
</a>

<script>
  // Handle "Coming Soon" badges visibility based on current date
  function updateComingSoonBadges() {
    const now = new Date();
    document.querySelectorAll('.coming-soon-badge').forEach((badge) => {
      const dateStr = (badge as HTMLElement).dataset.date;
      if (dateStr) {
        const pubDate = new Date(dateStr);
        if (pubDate > now) {
          badge.classList.remove('opacity-0');
        } else {
          badge.classList.add('hidden');
        }
      }
    });
  }

  // Run on load and after any content updates (like filtering)
  updateComingSoonBadges();
  
  // Re-run when filters might have changed visibility of items
  // We use a MutationObserver to catch when items are shown/hidden by the search script
  const observer = new MutationObserver(() => {
    updateComingSoonBadges();
  });

  const publicationGrid = document.querySelector('.publications-grid');
  if (publicationGrid) {
    observer.observe(publicationGrid, { attributes: true, subtree: true, attributeFilter: ['class', 'style'] });
  }

  // Also listen for a custom event if the search script triggers one
  document.addEventListener('filterUpdated', updateComingSoonBadges);
</script>
