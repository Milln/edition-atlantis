---
import { languages } from '../i18n/ui';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
// Remove the current language prefix from the pathname
// e.g., /en/books -> /books, /de/books -> /books
// If path maps to default lang (root '/'), this results in '/'
const currentPath = Astro.url.pathname.replace(new RegExp(`^/${lang}`), '') || '/';
---
<div class="relative group">
  <button class="flex items-center space-x-1 text-primary hover:text-accent font-medium uppercase">
    <span>{lang}</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div class="absolute right-0 top-full pt-2 w-24 hidden group-hover:block z-50">
    <div class="bg-white border border-gray-100 shadow-lg rounded-md overflow-hidden">
      {Object.entries(languages).map(([code, label]) => {
        // Logic to switch language
        let newPath;
        if (currentPath === '/' && lang === 'de') {
            // Special case for root
            newPath = `/${code}`;
        } else {
           newPath = `/${code}${currentPath}`;
        }
        // Clean up double slashes if any
        newPath = newPath.replace(/\/+/g, '/');
  
        return (
        <a
          href={newPath}
          class={`block px-4 py-2 text-sm hover:bg-gray-50 ${code === lang ? 'text-accent font-bold' : 'text-gray-700'}`}
        >
          {code.toUpperCase()}
        </a>
      )})}
    </div>
  </div>
</div>
