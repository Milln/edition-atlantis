---
import { languages } from '../i18n/ui';
import { getLangFromUrl, getPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

// Remove both the base URL and the current language prefix from the pathname
// e.g., /edition-atlantis/en/publications -> /publications
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, ''); // Remove trailing slash
let currentPath = Astro.url.pathname;

// Remove base URL if present
if (baseUrl && currentPath.startsWith(baseUrl)) {
  currentPath = currentPath.substring(baseUrl.length);
}

// Remove language prefix
currentPath = currentPath.replace(new RegExp(`^/${lang}`), '') || '/';
---
<div class="relative group">
  <button class="flex items-center space-x-1 text-primary hover:text-accent font-medium uppercase">
    <span>{lang}</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div class="absolute right-0 top-full pt-2 w-24 hidden group-hover:block z-50">
    <div class="bg-white border border-gray-100 shadow-lg rounded-md overflow-hidden">
      {Object.entries(languages).map(([code, label]) => {
        // Build the new path with the selected language
        let newPath;
        if (currentPath === '/' && code === 'de') {
            // Special case for German root
            newPath = getPath('/');
        } else if (currentPath === '/') {
            newPath = getPath(`/${code}`);
        } else {
           newPath = getPath(`/${code}${currentPath}`);
        }
  
        return (
        <a
          href={newPath}
          class={`block px-4 py-2 text-sm hover:bg-gray-50 ${code === lang ? 'text-accent font-bold' : 'text-gray-700'}`}
        >
          {code.toUpperCase()}
        </a>
      )})}
    </div>
  </div>
</div>
