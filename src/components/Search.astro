---
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { placeholder = "Search..." } = Astro.props;
---

<div class="search-wrapper relative w-full max-w-md" data-no-results={t('search.no_results')}>
  <div class="relative">
    <input 
      type="text" 
      placeholder={placeholder}
      class="search-input w-full bg-gray-50 border border-gray-200 text-gray-900 text-base rounded-sm focus:ring-primary focus:border-primary block p-3 pl-10 pr-10 outline-none transition-all"
    />
    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
    </div>
    <div class="search-spinner absolute inset-y-0 right-0 flex items-center pr-3 hidden">
        <svg class="animate-spin h-4 w-4 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
    </div>
  </div>

  <!-- Results Dropdown -->
  <div 
    class="search-results absolute z-50 w-full bg-white rounded-sm shadow-xl border border-gray-100 mt-2 max-h-96 overflow-y-auto hidden"
  >
    <!-- Results injected here -->
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  // Shared Fuse instance (lazy loaded)
  let fuse;

  async function getFuseInstance() {
    if (fuse) return fuse;
    
    try {
      const response = await fetch('/search-index.json');
      const data = await response.json();
      const options = {
        keys: ['title', 'author', 'isbn'],
        threshold: 0.3,
        minMatchCharLength: 2
      };
      fuse = new Fuse(data, options);
      return fuse;
    } catch (e) {
      console.error("Failed to load search index", e);
      return null;
    }
  }

  // Initialize all search components
  document.querySelectorAll('.search-wrapper').forEach(wrapper => {
    const searchInput = wrapper.querySelector('.search-input');
    const resultsContainer = wrapper.querySelector('.search-results');
    const spinner = wrapper.querySelector('.search-spinner');
    
    if (!searchInput || !resultsContainer || !spinner) return;

    // Preload index on hover or focus
    searchInput.addEventListener('focus', async () => {
        if (!fuse) {
            spinner.classList.remove('hidden');
            await getFuseInstance();
            spinner.classList.add('hidden');
        }
    });

    searchInput.addEventListener('input', async (e) => {
      const query = e.target.value;
      
      if (query.length < 2) {
        resultsContainer.classList.add('hidden');
        resultsContainer.innerHTML = '';
        return;
      }

      // Ensure fuse is loaded (if typing happened before focus completed)
      if (!fuse) {
          spinner.classList.remove('hidden');
          await getFuseInstance();
          spinner.classList.add('hidden');
      }
      
      if (!fuse) return; // Still failed

      const results = fuse.search(query);
      const lang = document.documentElement.lang || 'de';

      if (results.length > 0) {
        resultsContainer.classList.remove('hidden');
        resultsContainer.innerHTML = results.slice(0, 10).map(({ item }) => `
          <a href="/${item.lang}/books/${item.slug}" class="block p-3 hover:bg-gray-50 border-b border-gray-100 last:border-0 transition-colors">
            <div class="flex items-start">
               <div class="flex-shrink-0 mr-3">
                 <img src="${item.cover}" class="w-10 h-14 object-cover rounded-sm bg-gray-200" onerror="this.src='/images/placeholder-book.jpg'">
               </div>
               <div>
                 <div class="text-sm font-bold text-gray-900 line-clamp-1">${item.title}</div>
                 <div class="text-xs text-gray-600">${item.author}</div>
                 <div class="text-xs text-gray-400 mt-1 uppercase tracking-wide border border-gray-200 inline-block px-1 rounded-sm">${item.lang}</div>
               </div>
            </div>
          </a>
        `).join('');
      } else {
        resultsContainer.classList.remove('hidden');
        const noResultsText = wrapper.dataset.noResults || 'No results found.';
        resultsContainer.innerHTML = `<div class="p-4 text-sm text-gray-500 text-center">${noResultsText}</div>`;
      }
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !resultsContainer.contains(e.target)) {
        resultsContainer.classList.add('hidden');
      }
    });
  });
</script>
