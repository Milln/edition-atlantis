---
import { getCollection } from 'astro:content';
import { useTranslations, getPath } from '../i18n/utils';
import type { languages } from '../i18n/ui';
import PublicationCard from './PublicationCard.astro';

interface Props {
  lang: keyof typeof languages;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allPublications = await getCollection('publications');
const allAuthors = await getCollection('authors');

// Create a map for quick author lookup
const authorMap = new Map(allAuthors.map(a => [a.id, a.data.name]));

function getAuthorName(authorRef: { id: string }) {
  return authorMap.get(authorRef.id) || authorRef.id;
}

// Get the 3 newest publications
const newestPublications = allPublications
  .sort((a, b) => {
    const dateA = a.data.publicationDate ? a.data.publicationDate.valueOf() : 0;
    const dateB = b.data.publicationDate ? b.data.publicationDate.valueOf() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);
---

<!-- Hero Section -->
<section class="relative h-[80vh] flex items-center overflow-hidden bg-primary">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-0 -left-1/4 w-1/2 h-full bg-accent/30 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 -right-1/4 w-1/2 h-full bg-white/10 blur-[120px] rounded-full"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-3xl">
      <h1 class="font-serif text-3xl sm:text-4xl md:text-7xl font-bold text-white mb-6 leading-tight" set:html={t('home.hero.title')}>
      </h1>
      <p class="text-lg md:text-2xl text-white/80 mb-10 leading-relaxed font-light">
        {t('home.hero.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={getPath(`/${lang}/publications`)} class="px-8 py-4 bg-accent text-primary font-bold rounded-sm hover:bg-white hover:text-primary transition-all duration-300 shadow-xl hover:shadow-accent/20 text-center">
          {t('home.hero.browse')}
        </a>
        <a href={getPath(`/${lang}/authors`)} class="px-8 py-4 bg-transparent border border-white/30 text-white font-bold rounded-sm hover:bg-white/10 transition-all duration-300 text-center">
          {t('home.hero.authors')}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- New Releases Section -->
<section class="py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary mb-4">{t('home.new_releases')}</h2>
        <div class="h-1.5 w-20 bg-accent"></div>
      </div>
      <a href={getPath(`/${lang}/publications`)} class="text-primary font-bold hover:text-accent transition-colors flex items-center gap-2 group">
        {t('home.hero.browse')}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {newestPublications.map(publication => (
        <PublicationCard 
          publication={publication} 
          lang={lang} 
          authorName={getAuthorName(publication.data.author)}
          coAuthorNames={publication.data.coAuthors ? publication.data.coAuthors.map(ca => getAuthorName(ca)).join(', ') : undefined}
          showFilters={false}
        />
      ))}
    </div>
  </div>
</section>

<!-- Newsletter / Call to Action (Optional, for premium feel) -->
<section class="py-20 bg-gray-50 border-y border-gray-100">
    <div class="container mx-auto px-4 text-center">
        <h3 class="font-serif text-2xl md:text-3xl font-bold text-primary mb-6 italic">Edition Atlantis</h3>
        <p class="text-gray-500 max-w-2xl mx-auto mb-8">
            {t('home.hero.subtitle')}
        </p>
    </div>
</section>
