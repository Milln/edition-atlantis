---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { useTranslations, getPath } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export async function getStaticPaths() {
  const publications = await getCollection('publications');
  const languages = ['de', 'en', 'fr'];
  
  const paths = [];
  for (const publication of publications) {
    for (const lang of languages) {
      paths.push({
        params: { 
          lang: lang, 
          slug: publication.slug 
        },
        props: { publication },
      });
    }
  }

  return paths;
}

const { publication } = Astro.props;
const { Content } = await publication.render();
const author = await getEntry(publication.data.author); // Helper to get referenced author
const { lang: pageLang } = Astro.params;
const t = useTranslations(pageLang as keyof typeof languages);

const isFuture = publication.data.publicationDate ? publication.data.publicationDate > new Date() : false;
const formattedReleaseDate = publication.data.publicationDate ? publication.data.publicationDate.toLocaleDateString(pageLang, { day: 'numeric', month: 'long', year: 'numeric' }) : '';

// Get co-authors if present
let coAuthors = [];
if (publication.data.coAuthors) {
    for (const caRef of publication.data.coAuthors) {
        const ca = await getEntry(caRef);
        if (ca) coAuthors.push(ca);
    }
}

// Resolve description based on page language
let fullDescription = '';
let isMachineTranslated = false;

if (typeof publication.data.description === 'string') {
  fullDescription = publication.data.description;
} else if (publication.data.description) {
  const desc = publication.data.description;
  // Priority: current page lang → en → de → fr
  const langPriority = [pageLang, 'en', 'de', 'fr'].filter((l, i, arr) => arr.indexOf(l) === i) as ('de' | 'en' | 'fr')[];
  
  // Find the original language entry
  const originalLang = (['de', 'en', 'fr'] as const).find(l => desc[l]?.original === true);
  
  // Pick the best available text
  let selectedLang: 'de' | 'en' | 'fr' | undefined;
  for (const l of langPriority) {
    if (desc[l]?.text) {
      selectedLang = l;
      break;
    }
  }

  if (selectedLang && desc[selectedLang]) {
    fullDescription = desc[selectedLang]!.text;
    // Show hint if we know there's an original and the selected lang is not it
    if (originalLang && selectedLang !== originalLang) {
      isMachineTranslated = true;
    }
  }
}

// Truncate for meta tag
const metaDescription = fullDescription.substring(0, 160) + (fullDescription.length > 160 ? '...' : '');

---

<Layout title={publication.data.title} description={metaDescription}>
  <div class="container mx-auto px-4 py-12">
    <!-- Breadcrumb / Back -->
    <a href={getPath(`/${pageLang}/publications`)} class="inline-flex items-center text-sm text-gray-500 hover:text-primary mb-8 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      {t('nav.publications')}
    </a>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Sidebar / Covers -->
      <div class="md:col-span-4 lg:col-span-3 space-y-8">
        <div class="bg-gray-100 rounded-sm shadow-md overflow-hidden aspect-[2/3] cursor-zoom-in group" onclick="openLightbox(this.querySelector('img').src)">
           <img 
              src={getPath(publication.data.cover)}
              alt={publication.data.title}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              onError={`this.onerror=null;this.src='${getPath("/images/placeholder-publication.png")}';`}
            />

        </div>

        {publication.data.back && (
            <div class="bg-gray-100 rounded-sm shadow-md overflow-hidden aspect-[2/3] cursor-zoom-in group" onclick="openLightbox(this.querySelector('img').src)">
                <img 
                    src={getPath(publication.data.back)}
                    alt={`Back cover of ${publication.data.title}`}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    onError="this.style.display='none';"
                />
            </div>
        )}
      </div>

      <!-- Content -->
      <div class="md:col-span-8 lg:col-span-9">
        <div class="mb-4 text-sm text-accent font-bold uppercase tracking-wider flex items-center gap-2">
           <span>{publication.data.language.toUpperCase()}</span>
           {publication.data.publicationDate && <span>• {publication.data.publicationDate.getFullYear()}</span>}
           {isFuture && (
             <span class="bg-accent text-white text-[10px] px-1.5 py-0.5 rounded-sm coming-soon-tag">
               {t('publication.coming_soon').toUpperCase()}
             </span>
           )}
        </div>
        
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 mb-4 leading-snug md:leading-snug">
          {publication.data.title}
        </h1>

        <div class="flex flex-wrap items-center mb-8 pb-8 border-b border-gray-100 gap-4">
           {author && (
            <a href={getPath(`/${pageLang}/publications?author=${author.id}`)} class="flex items-center group">
               {author.data.photo && (
                 <img src={getPath(author.data.photo)} alt={author.data.name} class="w-10 h-10 rounded-full object-cover mr-3 bg-gray-200" onError="this.style.display='none'"/>
               )}
               <span class="text-lg font-medium text-gray-700 group-hover:text-primary transition-colors">
                 {author.data.name}
               </span>
            </a>
           )}
           {coAuthors.map(ca => (
               <a href={getPath(`/${pageLang}/publications?author=${ca.id}`)} class="flex items-center group">
                   {ca.data.photo && (
                     <img src={getPath(ca.data.photo)} alt={ca.data.name} class="w-8 h-8 rounded-full object-cover mr-2 bg-gray-200" onError="this.style.display='none'"/>
                   )}
                   <span class="text-lg font-medium text-gray-700 group-hover:text-primary transition-colors">
                     {ca.data.name}
                   </span>
               </a>
           ))}
        </div>

        {publication.data.price && (
            <div class="mb-8">
                <span class="text-3xl font-bold text-primary">
                    {Number(publication.data.price).toFixed(2)} €
                </span>
                <span class="text-sm text-gray-500 ml-2">({t('publication.invat') || 'incl. VAT'})</span>
            </div>
        )}

        {isFuture && (
          <div 
            class="flex items-start gap-3 mb-6 px-4 py-3 rounded-sm border border-primary/20 bg-primary/5 text-primary text-sm coming-soon-notice opacity-0 transition-opacity duration-300" 
            data-date={publication.data.publicationDate?.toISOString()}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>
              <strong class="font-bold">{t('publication.coming_soon')}</strong> • {t('publication.released_on').replace('{date}', formattedReleaseDate)}
            </span>
          </div>
        )}

        {isMachineTranslated && (
          <div class="flex items-start gap-3 mb-6 px-4 py-3 rounded-sm border border-amber-200 bg-amber-50 text-amber-800 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 shrink-0 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z" />
            </svg>
            <span>{t('publication.machine_translation_hint')}</span>
          </div>
        )}
        <div class="prose prose-lg prose-headings:font-serif prose-headings:text-primary prose-a:text-accent max-w-none mb-12 whitespace-pre-wrap">
          {fullDescription}
        </div>

        <div class="bg-gray-50 p-8 rounded-sm border border-gray-200 shadow-sm">
           <h3 class="font-serif text-2xl font-bold mb-8 pb-4 border-b border-gray-200 text-primary flex items-center gap-3">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
             </svg>
             {t('publication.details')}
           </h3>
           
           <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-10">
             <!-- Column 1: Specifications -->
             <div class="space-y-6">
               <ul class="space-y-4">
                 {publication.data.pageCount && (
                   <li class="flex items-start gap-3">
                     <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                       <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                       </svg>
                     </div>
                     <div>
                       <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">{t('publication.page_count')}</span>
                       <span class="text-sm font-medium text-gray-900">{publication.data.pageCount}</span>
                     </div>
                   </li>
                 )}
                 {publication.data.binding && (
                   <li class="flex items-start gap-3">
                     <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                       <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                       </svg>
                     </div>
                     <div>
                       <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">{t('publication.binding')}</span>
                       <span class="text-sm font-medium text-gray-900">{publication.data.binding}</span>
                     </div>
                   </li>
                 )}
                 {publication.data.category && (
                   <li class="flex items-start gap-3">
                     <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                       <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                       </svg>
                     </div>
                     <div>
                       <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">{t('publication.category')}</span>
                       <a href={getPath(`/${pageLang}/publications?category=${encodeURIComponent(publication.data.category)}`)} class="text-sm font-medium text-primary hover:underline transition-colors">
                         {publication.data.category}
                       </a>
                     </div>
                   </li>
                 )}
               </ul>
             </div>

             <!-- Column 2: Bibliographic -->
             <div class="space-y-6">
               <ul class="space-y-4">
                 <li class="flex items-start gap-3">
                   <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                     </svg>
                   </div>
                   <div>
                     <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">Language</span>
                     <span class="text-sm font-medium text-gray-900 uppercase">{publication.data.language}</span>
                   </div>
                 </li>
                 {publication.data.isbn10 && (
                   <li class="flex items-start gap-3">
                     <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                       <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                       </svg>
                     </div>
                     <div>
                       <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">{t('publication.isbn')} (10)</span>
                       <span class="text-sm font-mono text-gray-900">{publication.data.isbn10}</span>
                     </div>
                   </li>
                 )}
                 {publication.data.isbn13 && (
                   <li class="flex items-start gap-3">
                     <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                       <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                       </svg>
                     </div>
                     <div>
                       <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">{t('publication.isbn')} (13)</span>
                       <span class="text-sm font-mono text-gray-900">{publication.data.isbn13}</span>
                     </div>
                   </li>
                 )}
               </ul>
             </div>

             <!-- Column 3: Publishing -->
             <div class="space-y-6">
               <ul class="space-y-4">
                 <li class="flex items-start gap-3">
                   <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                     </svg>
                   </div>
                   <div>
                     <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">{t('publication.published')}</span>
                     <span class="text-sm font-medium text-gray-900">
                        {publication.data.publicationDate ? (
                          <span class="flex items-center gap-1">
                            {publication.data.publicationDate.getFullYear()}
                            {isFuture && <span class="text-accent text-[10px] uppercase font-bold">({t('publication.coming_soon')})</span>}
                          </span>
                        ) : (
                          t('publication.unknown_date') || 'Unknown'
                        )}
                     </span>
                   </div>
                 </li>
                 {author && (
                   <li class="flex items-start gap-3">
                     <div class="mt-1 bg-white p-1.5 rounded-sm border border-gray-100 shadow-sm text-primary">
                       <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                       </svg>
                     </div>
                     <div>
                       <span class="block text-[10px] uppercase font-bold text-gray-400 leading-none mb-1">{t('publication.author')}</span>
                       <div class="text-sm font-medium text-gray-900">
                         <a href={getPath(`/${pageLang}/publications?author=${author.id}`)} class="text-primary hover:underline transition-colors">{author.data.name}</a>
                         {coAuthors.length > 0 && (
                           <span class="text-gray-500">
                             {coAuthors.map(ca => (
                               <>, <a href={getPath(`/${pageLang}/publications?author=${ca.id}`)} class="text-primary hover:underline transition-colors">{ca.data.name}</a></>
                             ))}
                           </span>
                         )}
                       </div>
                     </div>
                   </li>
                 )}
               </ul>
             </div>
           </div>

           <!-- Acquisition Section -->
           <div class="flex flex-col md:flex-row items-center justify-between gap-8 pt-8 border-t border-gray-200">
              <div class="flex items-center gap-4">
                {publication.data.price && (
                  <div class="bg-primary/5 px-6 py-4 rounded-sm border border-primary/10">
                    <span class="block text-[10px] uppercase font-bold text-primary opacity-60 leading-none mb-1">{t('publication.price')}</span>
                    <span class="text-3xl font-bold text-primary tracking-tight">
                      {Number(publication.data.price).toFixed(2)} €
                    </span>
                    <span class="text-[10px] text-gray-400 block mt-1">{t('publication.invat')}</span>
                  </div>
                )}
              </div>
              
              <div class="flex flex-wrap gap-4 justify-center md:justify-end flex-grow">
                 <a href={`mailto:info@edition-atlantis.de?subject=Request Info: ${publication.data.title}`} class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-sm font-bold uppercase tracking-widest rounded-sm text-white bg-primary hover:bg-primary/90 transition-all hover:shadow-lg active:transform active:scale-95 min-w-[200px]">
                    {t('publication.request_info')}
                 </a>
                 {publication.data.amazonLink && (
                   <a href={publication.data.amazonLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 border-2 border-gray-900 text-sm font-bold uppercase tracking-widest rounded-sm text-gray-900 bg-transparent hover:bg-gray-900 hover:text-white transition-all hover:shadow-lg active:transform active:scale-95 min-w-[200px] group">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 transition-colors group-hover:text-white" viewBox="0 0 24 24" fill="currentColor">
                       <path d="M15.936 15.229c-2.834 2.407-6.155 3.637-9.759 3.637-3.932 0-7.391-1.39-10.177-3.637-.216-.174-.199-.452.059-.49 2.507-.373 5.095-.558 7.837-.558 2.054 0 4.086.101 6.022.29.336.031.535.317.216.558-.066.05-.133.1-.198.15zM23.161 15.408c-.149-.033-.3-.066-.35-.2-.1-.266-.149-.532-.149-.814 0-.897.433-1.744 1.164-2.327.731-.582 1.63-.848 2.528-.732 1.347.166 2.379.881 2.877 2.011l.249.565c.15.333.3.665.45.998.05.116.1.233.149.349l.1.25-.1.1c-.249.25-.499.499-.748.748l-.2.15c-.2-.05-.4-.1-.599-.149h-.1c-.1-.034-.149-.067-.2-.1l-.1-.1c-.05-.05-.1-.1-.149-.15-.05-.05-.1-.1-.149-.15-.05-.05-.1-.1-.149-.15-.05-.05-.1-.1-.15-.15s-.1-.1-.15-.15c-.05-.05-.1-.1-.149-.15-.05-.05-.1-.1-.149-.15-.05-.05-.1-.1-.149-.15-.05-.05-.1-.1-.15-.15s-.1-.1-.15-.15c-.05-.05-.1-.1-.149-.15-.05-.05-.1-.1-.149-.15s-.1-.1-.149-.15a1.71 1.71 0 00-.3-.3l-.15-.15c-.05-.05-.1-.1-.149-.15s-.1-.1-.149-.149z"/>
                     </svg>
                     {t('publication.buy_on_amazon')}
                   </a>
                 )}
              </div>
           </div>

           {publication.data.downloads && publication.data.downloads.length > 0 && (
            <div class="mt-12 pt-8 border-t border-gray-200">
               <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                 {publication.data.downloads.map(download => (
                   <li>
                     <a href={getPath(download.file)} target="_blank" rel="noopener noreferrer" class="flex items-center p-4 bg-white border border-gray-100 rounded-sm hover:border-red-200 hover:bg-red-50/30 transition-all group shadow-sm">
                       <span class="p-2.5 bg-red-50 text-red-600 rounded-sm mr-4 group-hover:bg-red-600 group-hover:text-white transition-colors">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                         </svg>
                       </span>
                       <span class="text-gray-700 group-hover:text-red-700 font-bold text-sm transition-colors uppercase tracking-wide">
                         {download.label}
                       </span>
                       <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-auto text-gray-300 group-hover:text-red-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                       </svg>
                     </a>
                   </li>
                 ))}
               </ul>
            </div>
           )}
        </div>
      </div>
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-black/95 hidden flex items-center justify-center opacity-0 transition-opacity duration-300" onclick="closeLightbox()">
    <div class="absolute top-4 right-4 text-white hover:text-gray-300 cursor-pointer p-2">
       <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
       </svg>
    </div>
    <img id="lightbox-img" src="" alt="Full size cover" class="max-h-[90vh] max-w-[90vw] object-contain shadow-2xl rounded-sm transform scale-95 transition-transform duration-300" onclick="event.stopPropagation()"/>
  </div>

  <script is:inline>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');

    function openLightbox(src) {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = src;
        lightbox.classList.remove('hidden');
        // Small delay to allow display:block to apply before opacity transition
        requestAnimationFrame(() => {
            lightbox.classList.remove('opacity-0');
            lightboxImg.classList.remove('scale-95');
        });
        document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }

    function closeLightbox() {
        if (!lightbox || !lightboxImg) return;
        lightbox.classList.add('opacity-0');
        lightboxImg.classList.add('scale-95');
        
        setTimeout(() => {
            lightbox.classList.add('hidden');
            lightboxImg.src = '';
            document.body.style.overflow = '';
        }, 300);
    }

    // Attach to window for inline onclick handlers
    window.openLightbox = openLightbox;
    window.closeLightbox = closeLightbox;

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });

    // Handle "Coming Soon" notice visibility
    function updateComingSoonNotice() {
        const now = new Date();
        const notice = document.querySelector('.coming-soon-notice');
        if (notice instanceof HTMLElement) {
            const dateStr = notice.dataset.date;
            if (dateStr) {
                const pubDate = new Date(dateStr);
                if (pubDate > now) {
                    notice.classList.remove('opacity-0');
                } else {
                    notice.classList.add('hidden');
                    document.querySelectorAll('.coming-soon-tag').forEach(tag => tag.classList.add('hidden'));
                }
            }
        }
    }
    updateComingSoonNotice();
  </script>
</Layout>
