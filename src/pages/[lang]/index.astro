---
import { languages } from '../../i18n/ui';
import { getPath } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;

// Redirect to books page for this language
return Astro.redirect(getPath(`/${lang}/books`));
---
