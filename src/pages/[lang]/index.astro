---
import Layout from '../../layouts/Layout.astro';
import { languages } from '../../i18n/ui';
import { useTranslations, getPath } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'de' } }, // Optional: If we want /de/ explicitly available
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---

<Layout title={t('nav.about')}>
  <div class="relative bg-primary text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style={`background-image: url('${import.meta.env.BASE_URL}/placeholder-hero.jpg')`}></div>
    <div class="container mx-auto px-4 py-32 relative z-10 text-center">
      <h1 class="font-serif text-5xl md:text-7xl font-bold mb-6 leading-tight" set:html={t('home.hero.title')} />
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10">
        {t('home.hero.subtitle')}
      </p>
      <div class="flex flex-col md:flex-row gap-4 justify-center">
        <a href={getPath(`/${lang}/books`)} class="bg-accent hover:bg-red-600 text-white px-8 py-3 rounded-sm font-semibold transition-all">
          {t('home.hero.browse')}
        </a>
        <a href={getPath(`/${lang}/about`)} class="border border-white hover:bg-white hover:text-primary text-white px-8 py-3 rounded-sm font-semibold transition-all">
          {t('home.hero.about')}
        </a>
      </div>
    </div>
  </div>

  <section class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary mb-12 text-center relative">
        {t('home.new_releases')}
        <span class="block w-20 h-1 bg-accent mx-auto mt-4"></span>
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Placeholder for Books content -->
        <div class="bg-white p-6 shadow-sm border border-gray-100 rounded-sm hover:shadow-md transition-shadow">
          <div class="aspect-[2/3] bg-gray-200 mb-4 rounded-sm"></div>
          <h3 class="font-serif text-xl font-bold mb-2">Book Title</h3>
          <p class="text-gray-500 text-sm mb-4">Author Name</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
