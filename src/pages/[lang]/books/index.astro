---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { useTranslations, getPath } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: 'de' } },
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const allBooks = await getCollection('books');
const allAuthors = await getCollection('authors');

// Create a map for quick author lookup
const authorMap = new Map(allAuthors.map(a => [a.id, a.data.name]));

// Get all books, sorted by date
const books = allBooks.sort((a, b) => {
    const dateA = a.data.publicationDate ? a.data.publicationDate.valueOf() : 0;
    const dateB = b.data.publicationDate ? b.data.publicationDate.valueOf() : 0;
    return dateB - dateA;
});

// Extract unique values for filters
const years = [...new Set(books.map(book => book.data.publicationDate ? book.data.publicationDate.getFullYear() : null).filter(Boolean))].sort((a, b) => (b as number) - (a as number));
const bookLanguages = [...new Set(books.map(book => book.data.language))];
const categories = [...new Set(books.map(book => book.data.category).filter(Boolean))].sort();

function getAuthorName(authorRef: { id: string }) {
  return authorMap.get(authorRef.id) || authorRef.id;
}
---

<Layout title={t('nav.books')}>
  <div class="bg-primary text-white py-12">
    <div class="container mx-auto px-4">
      <h1 class="font-serif text-4xl md:text-5xl font-bold">{t('nav.books')}</h1>
    </div>
  </div>

  <div class="container mx-auto px-4 py-12 flex flex-col md:flex-row gap-8">
    <!-- Sidebar Filters -->
    <aside class="w-full md:w-64 flex-shrink-0 space-y-8">


      <button id="filterToggle" class="md:hidden w-full flex items-center justify-between bg-white border border-gray-200 px-4 py-3 rounded-sm text-primary font-bold shadow-sm mb-4">
        <span id="filterToggleText" data-show={t('filter.show')} data-hide={t('filter.hide')}>{t('filter.show')}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <div id="filters" class="hidden md:block">
        <h3 class="font-serif text-lg font-bold text-primary mb-4 border-b border-gray-200 pb-2 hidden md:block">{t('filter.title')}</h3>

        <!-- Language Filter -->
        <div class="mb-6">
            <h4 class="font-semibold text-sm text-gray-900 mb-2">{t('filter.languages')}</h4>
            <div class="flex flex-wrap gap-2">
                <button class="filter-btn active px-3 py-1 bg-primary text-white text-xs rounded-sm transition-colors" data-filter="lang" data-value="all">{t('filter.all')}</button>
                {bookLanguages.map(l => (
                    <button class="filter-btn px-3 py-1 bg-gray-100 text-xs text-gray-700 hover:bg-primary hover:text-white rounded-sm transition-colors uppercase" data-filter="lang" data-value={l}>{l}</button>
                ))}
            </div>
        </div>

        <!-- Category Filter -->
        <div class="mb-6">
            <h4 class="font-semibold text-sm text-gray-900 mb-2">{t('filter.category')}</h4>
            <div class="flex flex-wrap gap-2">
                <button class="filter-btn active px-3 py-1 bg-primary text-white text-xs rounded-sm transition-colors" data-filter="category" data-value="all">{t('filter.all')}</button>
                {categories.map(c => (
                    <button class="filter-btn px-3 py-1 bg-gray-100 text-xs text-gray-700 hover:bg-primary hover:text-white rounded-sm transition-colors" data-filter="category" data-value={c}>{c}</button>
                ))}
            </div>
        </div>

        <!-- Author Filter -->
        <div class="mb-6">
          <h4 class="font-semibold text-sm text-gray-900 mb-2">{t('filter.authors')}</h4>
          <ul class="space-y-1 max-h-60 overflow-y-auto text-sm text-gray-600 custom-scrollbar">
            <li>
                <button class="filter-link w-full text-left pixel-antialiased hover:text-accent hover:bg-gray-50 transition-colors block py-1 px-2 rounded font-bold text-primary" data-filter="author" data-value="all">
                    {t('filter.all_authors')}
                </button>
            </li>
            {allAuthors.sort((a,b) => a.data.name.localeCompare(b.data.name)).map(author => (
              <li>
                <button class="filter-link w-full text-left pixel-antialiased hover:text-accent hover:bg-gray-50 transition-colors block py-1 px-2 rounded" data-filter="author" data-value={author.id}>
                  {author.data.name}
                </button>
              </li>
            ))}
          </ul>
        </div>

        <!-- Year Filter -->
        <div class="mb-6">
           <h4 class="font-semibold text-sm text-gray-900 mb-2">{t('filter.year')}</h4>
           <div class="flex flex-wrap gap-2">
             <button class="filter-btn active px-3 py-1 bg-primary text-white text-xs rounded-sm transition-colors" data-filter="year" data-value="all">{t('filter.all')}</button>
             {years.map(year => (
               <button class="filter-btn px-3 py-1 bg-gray-100 text-xs text-gray-700 hover:bg-primary hover:text-white rounded-sm transition-colors" data-filter="year" data-value={year}>
                 {year}
               </button>
             ))}
           </div>
        </div>
        
        <button id="resetFilters" class="text-xs text-accent underline mt-4 hover:text-primary">{t('filter.reset')}</button>
      </div>
    </aside>

    <!-- Book Grid -->
    <div class="flex-grow">
        <div class="mb-6 flex justify-between items-center h-8">
            <span id="resultsCount" class="text-sm text-gray-500 font-medium" data-template={t('books.results_count')}></span>
            <div class="flex items-center gap-2">
                <label for="sortSelect" class="text-sm text-gray-600 font-medium">{t('books.sort_by')}</label>
                <select id="sortSelect" class="px-3 py-1 border border-gray-300 rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary">
                    <option value="year-desc" selected>{t('books.sort_year_desc')}</option>
                    <option value="year-asc">{t('books.sort_year_asc')}</option>
                    <option value="title-asc">{t('books.sort_title_asc')}</option>
                    <option value="title-desc">{t('books.sort_title_desc')}</option>
                </select>
            </div>
        </div>
        <div id="bookGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {books.map((book) => {
            const authorId = book.data.author.id;
            const coAuthorIds = book.data.coAuthors ? book.data.coAuthors.map(a => a.id).join(' ') : '';
            const allAuthorIds = `${authorId} ${coAuthorIds}`;
            
            return (
            <a 
                href={getPath(`/${lang}/books/${book.slug}`)} 
                class="book-item group block bg-white border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1"
                data-lang={book.data.language}
                data-author={allAuthorIds}
                data-author-names={`${getAuthorName(book.data.author)} ${book.data.coAuthors ? book.data.coAuthors.map(ca => getAuthorName(ca)).join(' ') : ''}`}
                data-year={book.data.publicationDate ? book.data.publicationDate.getFullYear() : 'unknown'}
                data-category={book.data.category || ''}
                data-title={book.data.title.toLowerCase()}
                data-isbn={book.data.isbn || ''}
            >
              <div class="aspect-[2/3] overflow-hidden bg-gray-100 relative">
                <img 
                  src={`${import.meta.env.BASE_URL}/${book.data.cover.replace(/^\//, '')}`}
                  alt={book.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                  onError={`this.onerror=null;this.src='${import.meta.env.BASE_URL}/images/placeholder-book.png';`}
                />
                <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors duration-300"></div>
                {book.data.price && (
                    <div class="absolute bottom-2 right-2 bg-black/70 text-white text-xs px-2 py-1 rounded">
                        {Number(book.data.price).toFixed(2)} €
                    </div>
                )}
              </div>
              <div class="p-4">
                <h3 class="font-serif text-lg font-bold text-gray-900 group-hover:text-primary line-clamp-2 leading-tight mb-1" title={book.data.title}>
                  {book.data.title}
                </h3>
                <p class="text-sm text-accent font-medium mb-1">
                    {getAuthorName(book.data.author)}{book.data.coAuthors && (
                        <span>, {book.data.coAuthors.map(ca => getAuthorName(ca)).join(', ')}</span>
                    )}
                </p>
                <div class="flex justify-between items-center mt-2">
                     <p class="text-xs text-gray-400">
                      {book.data.publicationDate ? book.data.publicationDate.getFullYear() : t('book.unknown_date') || 'Unknown'}
                    </p>
                    <span class="text-xs font-bold uppercase text-gray-300 bg-gray-50 px-1 rounded">{book.data.language}</span>
                </div>
               
              </div>
            </a>
          )})}
        </div>
        
        <div id="noResults" class="hidden text-center py-20 text-gray-500">
          <p id="noResultsMessage" data-default={t('books.not_found')} data-filtering={t('books.no_results_filtering')}></p>
        </div>
        
        <div class="text-center mt-12 mb-8">
            <p id="resultsCountBottom" class="text-sm text-gray-500 font-medium mb-6" data-template={t('books.results_count')}></p>
            <div id="loadMoreContainer" class="hidden inline-block">
                <button id="loadMoreBtn" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-sm text-white bg-primary hover:bg-primary/90 transition-colors shadow-sm">
                    {t('books.load_more') || 'Load More'}
                </button>
            </div>
        </div>
    </div>
  </div>
</Layout>

<script>
    import Fuse from 'fuse.js';

    // Client-side filtering logic
    document.addEventListener('DOMContentLoaded', () => {
        const grid = document.getElementById('bookGrid');
        const noResults = document.getElementById('noResults');
        const noResultsMessage = document.getElementById('noResultsMessage');
        const resultsCount = document.getElementById('resultsCount');
        const resultsCountBottom = document.getElementById('resultsCountBottom');
        const searchInputs = document.querySelectorAll('.search-input');
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        const loadMoreContainer = document.getElementById('loadMoreContainer');
        
        let fuse: any = null;
        
        function initFuse() {
            const currentItems = grid?.querySelectorAll('.book-item');
            if (!currentItems) return;
            const data = Array.from(currentItems).map((el: any) => ({
                id: el.dataset.isbn, // Use ISBN as identifier (though not strictly needed)
                title: el.dataset.title,
                author: el.dataset.authorNames,
                isbn: el.dataset.isbn,
                originalEl: el // Keep reference to the element
            }));

            fuse = new Fuse(data, {
                keys: ['title', 'author', 'isbn'],
                threshold: 0.4,
                ignoreLocation: true,
                getFn: (obj, path) => {
                  const value = (obj as any)[path as string];
                  if (typeof value === 'string') {
                    return value
                      .normalize('NFD')
                      .replace(/[\u0300-\u036f]/g, '') // Remove diacritics
                      .replace(/['']/g, '') // Remove apostrophes
                      .toLowerCase();
                  }
                  return value;
                }
            });
        }
        
        initFuse();
        
        const ITEMS_PER_PAGE = 12;
        let currentLimit = ITEMS_PER_PAGE;
        
        // Parse URL params
        const urlParams = new URLSearchParams(window.location.search);
        
        let currentFilters = {
            lang: urlParams.get('lang') || 'all',
            author: urlParams.get('author') || 'all',
            year: urlParams.get('year') || 'all',
            category: urlParams.get('category') || 'all',
            search: urlParams.get('search') || ''
        };

        // Initialize UI based on filters
        function initUI() {
             if (currentFilters.lang !== 'all') {
                 document.querySelectorAll('.filter-btn[data-filter="lang"]').forEach(b => {
                     b.classList.remove('bg-primary', 'text-white', 'active');
                     b.classList.add('bg-gray-100', 'text-gray-700');
                     if ((b as HTMLElement).dataset.value === currentFilters.lang) {
                         b.classList.add('bg-primary', 'text-white', 'active');
                         b.classList.remove('bg-gray-100', 'text-gray-700');
                     }
                 });
             }
             if (currentFilters.year !== 'all') {
                 document.querySelectorAll('.filter-btn[data-filter="year"]').forEach(b => {
                     b.classList.remove('bg-primary', 'text-white', 'active');
                     b.classList.add('bg-gray-100', 'text-gray-700');
                     if ((b as HTMLElement).dataset.value === currentFilters.year) {
                         b.classList.add('bg-primary', 'text-white', 'active');
                         b.classList.remove('bg-gray-100', 'text-gray-700');
                     }
                 });
             }
             if (currentFilters.category !== 'all') {
                 document.querySelectorAll('.filter-btn[data-filter="category"]').forEach(b => {
                     b.classList.remove('bg-primary', 'text-white', 'active');
                     b.classList.add('bg-gray-100', 'text-gray-700');
                     if ((b as HTMLElement).dataset.value === currentFilters.category) {
                         b.classList.add('bg-primary', 'text-white', 'active');
                         b.classList.remove('bg-gray-100', 'text-gray-700');
                     }
                 });
             }
             if (currentFilters.author !== 'all') {
                 document.querySelectorAll('.filter-link').forEach(l => {
                     l.classList.remove('text-primary', 'font-bold');
                 });
                 const link = document.querySelector(`.filter-link[data-value="${currentFilters.author}"]`);
                 if (link) {
                     link.classList.add('text-primary', 'font-bold');
                     // Scroll the selected author into view
                     link.scrollIntoView({ behavior: 'smooth', block: 'center' });
                 }
             }
             if (currentFilters.search && searchInputs.length > 0) {
                 searchInputs.forEach(input => (input as HTMLInputElement).value = currentFilters.search);
             }
             applyFilters();
        }

        function updateURL() {
            const params = new URLSearchParams();
            if (currentFilters.lang !== 'all') params.set('lang', currentFilters.lang);
            if (currentFilters.author !== 'all') params.set('author', currentFilters.author);
            if (currentFilters.year !== 'all') params.set('year', currentFilters.year);
            if (currentFilters.category !== 'all') params.set('category', currentFilters.category);
            if (currentFilters.search) params.set('search', currentFilters.search);
            
            const newUrl = `${window.location.pathname}${params.toString() ? '?' + params.toString() : ''}`;
            window.history.replaceState({}, '', newUrl);
        }

        function applyFilters() {
            const currentItems = grid?.querySelectorAll('.book-item');
            if (!currentItems) return;
            let visibleCount = 0;
            
            // Normalize text for fuzzy matching (same as Search component)
            const normalizeText = (text: string) => {
                return text
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '') // Remove diacritics
                    .replace(/['']/g, '') // Remove apostrophes
                    .toLowerCase();
            };

            let matchingItems: HTMLElement[] = [];
            let searchMatchSet = new Set();
            
            if (currentFilters.search) {
                if (!fuse) initFuse();
                const searchResults = fuse.search(currentFilters.search);
                searchResults.forEach((res: any) => searchMatchSet.add(res.item.originalEl));
            }

            currentItems.forEach(item => {
                const el = item as HTMLElement;
                const lang = el.dataset.lang;
                const authors = el.dataset.author?.split(' ') || [];
                const year = el.dataset.year;
                const category = el.dataset.category || '';

                const matchLang = currentFilters.lang === 'all' || lang === currentFilters.lang;
                const matchYear = currentFilters.year === 'all' || year === currentFilters.year;
                const matchCategory = currentFilters.category === 'all' || category === currentFilters.category;
                const matchAuthor = currentFilters.author === 'all' || authors.includes(currentFilters.author);
                
                const matchSearch = currentFilters.search === '' || searchMatchSet.has(el);

                if (matchLang && matchYear && matchAuthor && matchSearch && matchCategory) {
                    matchingItems.push(el);
                } else {
                    el.classList.add('hidden');
                }
            });
            
            visibleCount = matchingItems.length;
            
            // Apply pagination limit
            matchingItems.forEach((el, index) => {
                 if (index < currentLimit) {
                     el.classList.remove('hidden');
                 } else {
                     el.classList.add('hidden');
                 }
            });
            
            // Handle Load More button visibility
            if (visibleCount > currentLimit) {
                 loadMoreContainer?.classList.remove('hidden');
            } else {
                 loadMoreContainer?.classList.add('hidden');
            }

            if (visibleCount === 0) {
                noResults?.classList.remove('hidden');
                if (noResultsMessage) {
                    const isFiltering = currentFilters.lang !== 'all' || currentFilters.author !== 'all' || currentFilters.year !== 'all' || currentFilters.category !== 'all' || currentFilters.search !== '';
                    noResultsMessage.textContent = (isFiltering ? noResultsMessage.dataset.filtering : noResultsMessage.dataset.default) || '';
                }
            } else {
                noResults?.classList.add('hidden');
            }

            if (resultsCount) {
                const template = resultsCount.dataset.template || 'Showing {shown} of {total} results';
                const shownStr = Math.min(visibleCount, currentLimit).toString();
                const totalStr = visibleCount.toString();
                const processedText = template.replace('{shown}', shownStr).replace('{total}', totalStr);
                
                resultsCount.textContent = processedText;
                if (resultsCountBottom) {
                    // Hide the bottom counter completely if 0 results, otherwise update it
                    if (visibleCount === 0) {
                        resultsCountBottom.style.display = 'none';
                    } else {
                        resultsCountBottom.style.display = '';
                        resultsCountBottom.textContent = processedText;
                    }
                }
            }

            updateURL();
        }

        // Event Listeners for Buttons
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const target = e.currentTarget as HTMLElement;
                const filterType = target.dataset.filter;
                const value = target.dataset.value;

                if (filterType && value) {
                    // Update active state
                    target.parentElement?.querySelectorAll('.filter-btn').forEach(b => {
                        b.classList.remove('bg-primary', 'text-white');
                        b.classList.add('bg-gray-100', 'text-gray-700');
                        b.classList.remove('active');
                    });
                    
                    target.classList.remove('bg-gray-100', 'text-gray-700');
                    target.classList.add('bg-primary', 'text-white');
                    target.classList.add('active');

                    // @ts-ignore
                    currentFilters[filterType] = value;
                    currentLimit = ITEMS_PER_PAGE;
                    applyFilters();
                }
            });
        });

        // Event Listeners for Author Links
        document.querySelectorAll('.filter-link').forEach(btn => {
             btn.addEventListener('click', (e) => {
                const target = e.currentTarget as HTMLElement;
                const value = target.dataset.value;
                if(value) {
                     // Reset visual state for links
                    document.querySelectorAll('.filter-link').forEach(l => {
                        l.classList.remove('text-primary', 'font-bold');
                    });
                    target.classList.add('text-primary', 'font-bold');
                    
                    currentFilters.author = value;
                    currentLimit = ITEMS_PER_PAGE;
                    applyFilters();
                }
             })
        });
        
        if (searchInputs.length > 0) {
            searchInputs.forEach(input => {
                input.addEventListener('input', (e) => {
                    const target = e.target as HTMLInputElement;
                    currentFilters.search = target.value;
                    currentLimit = ITEMS_PER_PAGE;
                    applyFilters();
                });
            });
        }
        
        document.getElementById('resetFilters')?.addEventListener('click', () => {
            currentFilters = { lang: 'all', author: 'all', year: 'all', category: 'all', search: '' };
            // Reset UI
             document.querySelectorAll('.filter-btn').forEach(b => {
                 b.classList.remove('bg-primary', 'text-white', 'active');
                 b.classList.add('bg-gray-100', 'text-gray-700');
             });
             // Reset to "All" active
             document.querySelectorAll('.filter-btn[data-value="all"]').forEach(b => {
                 b.classList.add('bg-primary', 'text-white', 'active');
                 b.classList.remove('bg-gray-100', 'text-gray-700');
             });

             document.querySelectorAll('.filter-link').forEach(l => l.classList.remove('text-primary', 'font-bold'));
             document.querySelector('.filter-link[data-value="all"]')?.classList.add('text-primary', 'font-bold');

             if(searchInputs.length > 0) searchInputs.forEach(input => (input as HTMLInputElement).value = '');
             currentLimit = ITEMS_PER_PAGE;
             applyFilters();
        });
        
        // Load More functionality
        loadMoreBtn?.addEventListener('click', () => {
             currentLimit += ITEMS_PER_PAGE;
             applyFilters();
        });
        
        // Sort functionality
        const sortSelect = document.getElementById('sortSelect') as HTMLSelectElement;
        if (sortSelect) {
            sortSelect.addEventListener('change', () => {
                const sortValue = sortSelect.value;
                const bookGrid = document.getElementById('bookGrid');
                if (!bookGrid) return;
                
                const books = Array.from(bookGrid.querySelectorAll('.book-item'));
                
                books.sort((a, b) => {
                    const aEl = a as HTMLElement;
                    const bEl = b as HTMLElement;
                    
                    switch(sortValue) {
                        case 'title-asc':
                            return (aEl.dataset.title || '').localeCompare(bEl.dataset.title || '');
                        case 'title-desc':
                            return (bEl.dataset.title || '').localeCompare(aEl.dataset.title || '');
                        case 'year-desc': {
                            const yA = aEl.dataset.year === 'unknown' ? 0 : parseInt(aEl.dataset.year || '0', 10);
                            const yB = bEl.dataset.year === 'unknown' ? 0 : parseInt(bEl.dataset.year || '0', 10);
                            return yB - yA;
                        }
                        case 'year-asc': {
                            const yA = aEl.dataset.year === 'unknown' ? Number.MAX_SAFE_INTEGER : parseInt(aEl.dataset.year || '0', 10);
                            const yB = bEl.dataset.year === 'unknown' ? Number.MAX_SAFE_INTEGER : parseInt(bEl.dataset.year || '0', 10);
                            return yA - yB;
                        }
                        default:
                            return 0;
                    }
                });
                
                // Re-append in sorted order
                books.forEach(book => bookGrid.appendChild(book));
                
                // Re-apply filters to enforce pagination on newly sorted items
                currentLimit = ITEMS_PER_PAGE;
                applyFilters();
            });
            
            // Trigger initial sort (alphabetical by default)
            sortSelect.dispatchEvent(new Event('change'));
        }
        
        
        // Mobile Filter Toggle
        const filterToggle = document.getElementById('filterToggle');
        const filterToggleText = document.getElementById('filterToggleText');
        const filtersContainer = document.getElementById('filters');
        const filterIcon = filterToggle?.querySelector('svg');

        filterToggle?.addEventListener('click', () => {
            filtersContainer?.classList.toggle('hidden');
            const isHidden = filtersContainer?.classList.contains('hidden');
            
            if (filterToggleText) {
                filterToggleText.textContent = isHidden ? 
                    filterToggleText.dataset.show : 
                    filterToggleText.dataset.hide;
            }
            
            if (filterIcon) {
                filterIcon.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
            }
        });



        initUI();
    });

</script>

<style>
  /* Custom Scrollbar for author list */
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #f1f1f1;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #ccc; 
    border-radius: 2px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #999; 
  }
  
  /* Prevent hover background on active author */
  .filter-link.bg-primary:hover {
    background-color: rgb(var(--color-primary)) !important;
  }

</style>
