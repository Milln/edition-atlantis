---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { useTranslations, getPath } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export async function getStaticPaths() {
  const books = await getCollection('books');
  const languages = ['de', 'en', 'fr'];
  
  const paths = [];
  for (const book of books) {
    for (const lang of languages) {
      paths.push({
        params: { 
          lang: lang, 
          slug: book.slug 
        },
        props: { book },
      });
    }
  }

  return paths;
}

const { book } = Astro.props;
const { Content } = await book.render();
const author = await getEntry(book.data.author); // Helper to get referenced author
const { lang: pageLang } = Astro.params;
const t = useTranslations(pageLang as keyof typeof languages);

// Get co-authors if present
let coAuthors = [];
if (book.data.coAuthors) {
    for (const caRef of book.data.coAuthors) {
        const ca = await getEntry(caRef);
        if (ca) coAuthors.push(ca);
    }
}

// Resolve description based on page language
let metaDescription = '';
if (typeof book.data.description === 'string') {
  metaDescription = book.data.description;
} else {
  // It's an object with localized keys
  // @ts-ignore
  metaDescription = book.data.description[pageLang] || book.data.description['en'] || book.data.description['de'] || '';
}

// Truncate for meta tag if needed
metaDescription = metaDescription.substring(0, 160) + (metaDescription.length > 160 ? '...' : '');

---

<Layout title={book.data.title} description={metaDescription}>
  <div class="container mx-auto px-4 py-12">
    <!-- Breadcrumb / Back -->
    <a href={getPath(`/${pageLang}/books`)} class="inline-flex items-center text-sm text-gray-500 hover:text-primary mb-8 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      {t('nav.books')}
    </a>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Sidebar / Covers -->
      <div class="md:col-span-4 lg:col-span-3 space-y-8">
        <div class="bg-gray-100 rounded-sm shadow-md overflow-hidden aspect-[2/3] cursor-zoom-in group" onclick="openLightbox(this.querySelector('img').src)">
           <img 
              src={`${import.meta.env.BASE_URL}/${book.data.cover.replace(/^\//, '')}`}
              alt={book.data.title}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              onError={`this.onerror=null;this.src='${import.meta.env.BASE_URL}/images/placeholder-book.png';`}
            />

        </div>

        {book.data.back && (
            <div class="bg-gray-100 rounded-sm shadow-md overflow-hidden aspect-[2/3] cursor-zoom-in group" onclick="openLightbox(this.querySelector('img').src)">
                <img 
                    src={`${import.meta.env.BASE_URL}/${book.data.back.replace(/^\//, '')}`}
                    alt={`Back cover of ${book.data.title}`}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    onError="this.style.display='none';"
                />
            </div>
        )}
      </div>

      <!-- Content -->
      <div class="md:col-span-8 lg:col-span-9">
        <div class="mb-4 text-sm text-accent font-bold uppercase tracking-wider">
           {book.data.language.toUpperCase()} {book.data.publicationDate ? `• ${book.data.publicationDate.getFullYear()}` : ''}
        </div>
        
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 mb-4 leading-tight">
          {book.data.title}
        </h1>

        <div class="flex flex-wrap items-center mb-8 pb-8 border-b border-gray-100 gap-4">
           {author && (
            <a href={getPath(`/${pageLang}/books?author=${author.id}`)} class="flex items-center group">
               {author.data.photo && (
                 <img src={`${import.meta.env.BASE_URL}/${author.data.photo.replace(/^\//,'')}`} alt={author.data.name} class="w-10 h-10 rounded-full object-cover mr-3 bg-gray-200" onError="this.style.display='none'"/>
               )}
               <span class="text-lg font-medium text-gray-700 group-hover:text-primary transition-colors">
                 {author.data.name}
               </span>
            </a>
           )}
           {coAuthors.map(ca => (
               <a href={getPath(`/${pageLang}/books?author=${ca.id}`)} class="flex items-center group">
                   {ca.data.photo && (
                     <img src={`${import.meta.env.BASE_URL}/${ca.data.photo.replace(/^\//,'')}`} alt={ca.data.name} class="w-8 h-8 rounded-full object-cover mr-2 bg-gray-200" onError="this.style.display='none'"/>
                   )}
                   <span class="text-lg font-medium text-gray-700 group-hover:text-primary transition-colors">
                     {ca.data.name}
                   </span>
               </a>
           ))}
        </div>

        {book.data.price && (
            <div class="mb-8">
                <span class="text-3xl font-bold text-primary">
                    {Number(book.data.price).toFixed(2)} €
                </span>
                <span class="text-sm text-gray-500 ml-2">({t('book.invat') || 'incl. VAT'})</span>
            </div>
        )}

        <div class="prose prose-lg prose-headings:font-serif prose-headings:text-primary prose-a:text-accent max-w-none mb-12">
          <Content />
        </div>

        <div class="bg-gray-50 p-6 rounded-sm border border-gray-200">
           <h3 class="font-serif text-lg font-bold mb-4">{t('book.details')}</h3>
           <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-4 text-sm">
             {book.data.isbn && (
               <div class="flex flex-col">
                 <dt class="text-gray-500">{t('book.isbn')}</dt>
                 <dd class="font-mono text-gray-900">{book.data.isbn}</dd>
               </div>
             )}
             <div class="flex flex-col">
                 <dt class="text-gray-500">{t('book.published')}</dt>
                 <dd class="text-gray-900">{book.data.publicationDate ? book.data.publicationDate.getFullYear() : t('book.unknown_date') || 'Unknown'}</dd>
             </div>
              {author && (
                <div class="flex flex-col">
                   <dt class="text-gray-500">{t('book.author')}</dt>
                   <dd class="text-gray-900">
                      <a href={getPath(`/${pageLang}/books?author=${author.id}`)} class="hover:underline hover:text-primary font-medium">
                         {author.data.name}
                      </a>
                      {coAuthors.length > 0 && (
                         <span>, {coAuthors.map((ca, i) => (
                             <>
                             {i > 0 && ', '}
                             <a href={getPath(`/${pageLang}/books?author=${ca.id}`)} class="hover:underline hover:text-primary">{ca.data.name}</a>
                             </>
                         ))}</span>
                      )}
                   </dd>
                </div>
              )}
             {book.data.price && (
                <div class="flex flex-col">
                  <dt class="font-bold text-gray-900">{t('book.price')}</dt>
                  <dd class="text-gray-700">{Number(book.data.price).toFixed(2)} €</dd>
                </div>
              )}
              {book.data.category && (
                <div class="flex flex-col">
                  <dt class="font-bold text-gray-900">{t('book.category')}</dt>
                  <dd class="text-gray-700">{book.data.category}</dd>
                </div>
              )}
           </dl>
           
           <div class="mt-8 pt-6 border-t border-gray-200 flex justify-center md:justify-start">
              <a href={`mailto:info@edition-atlantis.de?subject=Request Info: ${book.data.title}`} class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-sm text-white bg-primary hover:bg-primary/90 transition-colors">
                 {t('book.request_info')}
              </a>
           </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-black/95 hidden flex items-center justify-center opacity-0 transition-opacity duration-300" onclick="closeLightbox()">
    <div class="absolute top-4 right-4 text-white hover:text-gray-300 cursor-pointer p-2">
       <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
       </svg>
    </div>
    <img id="lightbox-img" src="" alt="Full size cover" class="max-h-[90vh] max-w-[90vw] object-contain shadow-2xl rounded-sm transform scale-95 transition-transform duration-300" onclick="event.stopPropagation()"/>
  </div>

  <script is:inline>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');

    function openLightbox(src) {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = src;
        lightbox.classList.remove('hidden');
        // Small delay to allow display:block to apply before opacity transition
        requestAnimationFrame(() => {
            lightbox.classList.remove('opacity-0');
            lightboxImg.classList.remove('scale-95');
        });
        document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }

    function closeLightbox() {
        if (!lightbox || !lightboxImg) return;
        lightbox.classList.add('opacity-0');
        lightboxImg.classList.add('scale-95');
        
        setTimeout(() => {
            lightbox.classList.add('hidden');
            lightboxImg.src = '';
            document.body.style.overflow = '';
        }, 300);
    }

    // Attach to window for inline onclick handlers
    window.openLightbox = openLightbox;
    window.closeLightbox = closeLightbox;

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });
  </script>
</Layout>
