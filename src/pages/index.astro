---
import Layout from '../layouts/Layout.astro';

// Since we are using prefixDefaultLocale: false, this page handles the root '/' path, which is German by default.
// In a real app we might reuse the component from [lang]/index.astro
---
<Layout title="Home">
  <div class="relative bg-primary text-white overflow-hidden">
    <div class="absolute inset-0 bg-[url('/placeholder-hero.jpg')] bg-cover bg-center opacity-20"></div>
    <div class="container mx-auto px-4 py-32 relative z-10 text-center">
      <h1 class="font-serif text-5xl md:text-7xl font-bold mb-6 leading-tight">
        Welten neu <br/> <span class="text-accent">entdecken</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10">
        Premium-Literatur für die Moderne. Kuratierte Sammlungen aus Belletristik, Geschichte und Kunst.
      </p>
      <div class="flex flex-col md:flex-row gap-4 justify-center">
        <a href="/de/books" class="bg-accent hover:bg-red-600 text-white px-8 py-3 rounded-sm font-semibold transition-all">
          Katalog durchsuchen
        </a>
        <a href="/de/about" class="border border-white hover:bg-white hover:text-primary text-white px-8 py-3 rounded-sm font-semibold transition-all">
          Unsere Geschichte
        </a>
      </div>
    </div>
  </div>

  <section class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary mb-12 text-center relative">
        Neuerscheinungen
        <span class="block w-20 h-1 bg-accent mx-auto mt-4"></span>
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Placeholder for Books content -->
        <div class="bg-white p-6 shadow-sm border border-gray-100 rounded-sm hover:shadow-md transition-shadow">
          <div class="aspect-[2/3] bg-gray-200 mb-4 rounded-sm"></div>
          <h3 class="font-serif text-xl font-bold mb-2">Buchtitel</h3>
          <p class="text-gray-500 text-sm mb-4">Autor Name</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
